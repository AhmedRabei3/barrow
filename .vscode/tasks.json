{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Next.js dev server",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true
		},
		{
			"label": "Check PostgreSQL port",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$ok=(Test-NetConnection -ComputerName localhost -Port 5432 -WarningAction SilentlyContinue).TcpTestSucceeded; Write-Output \"PG_PORT_OPEN=$ok\""
			],
			"isBackground": false
		},
		{
			"label": "Lint (next lint)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			],
			"isBackground": false
		},
		{
			"label": "Build (next build)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Build only (next build)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Build CI (next build)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$env:CI='1'; npm run build"
			],
			"isBackground": false
		},
		{
			"label": "Check localhost 3000",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$ok=(Test-NetConnection -ComputerName localhost -Port 3000 -WarningAction SilentlyContinue).TcpTestSucceeded; Write-Output \"NEXT_PORT_OPEN=$ok\""
			],
			"isBackground": false
		},
		{
			"label": "Probe default items API",
			"type": "shell",
			"command": "py",
			"args": [
				"-c",
				"import urllib.request, urllib.error; req=urllib.request.Request('http://localhost:3000/api/items?page=1&limit=20');\ntry:\n    print(urllib.request.urlopen(req).read().decode())\nexcept urllib.error.HTTPError as e:\n    print('HTTP', e.code)\n    print(e.read().decode())"
			],
			"isBackground": false
		},
		{
